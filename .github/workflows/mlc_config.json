{
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "{{BASEURL}}/"
    }
  ],
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https://example.com" },
    { "pattern": "^file:///github/workspace/Users/" },
    { "pattern": "^file:///Users/" },
    { "pattern": "path/to/SSOT" },
    { "pattern": "path/to/DOC" },
    { "pattern": "01_systems/" },
    { "pattern": "temp-" },
    { "pattern": "\\.cursor/" }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206]
}
