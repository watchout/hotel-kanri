{
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "{{BASEURL}}/"
    }
  ],
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https://example.com" },
    { "pattern": "^https://stg.example.com" },
    { "pattern": "^file:///" },
    { "pattern": "path/to/SSOT" },
    { "pattern": "path/to/DOC" },
    { "pattern": "^https://dev[-\\.]" },
    { "pattern": "^https://app\\.datadoghq\\.com" },
    { "pattern": "^https://console\\.aws\\.amazon\\.com" },
    { "pattern": "^https://github\\.com/example/" },
    { "pattern": "^https://github\\.com/<org>" },
    { "pattern": "^https://common\\.hotel-system\\.com" },
    { "pattern": "^https://docs/" },
    { "pattern": "omotenasuai\\.com" }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206]
}
